<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  .scene {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    padding: 2rem 0;
  }
  .label {
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 10px;
    text-align: center;
  }
  .card {
    width: 356px;
    height: 200px;
    border-radius: 14px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;

    border: 2.5px solid #9fe1cb;
  }
  /* frontal */
  .cf-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: #bfdceb;
    border-radius: 0 2px 2px 0;
    z-index: 4;
  }
  .cf-content {
    position: absolute;
    inset: 0;
    padding: 22px 22px 18px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 3;
  }
  .cf-tag {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: #9fe1cb;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .cf-name-first {
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
  }
  .cf-name-last {
    font-size: 20px;
    font-weight: 700;
    color: #5dcaa5;
    line-height: 1.1;
  }
  .cf-role {
    margin-top: 7px;
    font-size: 9.5px;
    color: rgba(255, 255, 255, 0.45);
    font-style: italic;
  }
  .cf-stack {
    display: flex;
    gap: 5px;
    margin-top: 9px;
    flex-wrap: wrap;
  }
  .cf-pill {
    font-size: 8px;
    font-weight: 700;
    color: #9fe1cb;
    border: 1px solid rgba(159, 225, 203, 0.3);
    border-radius: 20px;
    padding: 2px 9px;
    letter-spacing: 0.04em;
  }
  .cf-bottom {
    display: flex;
    flex-direction: column;
    gap: 5px;
    border-top: 0.5px solid rgba(255, 255, 255, 0.09);
    padding-top: 10px;
  }
  .cf-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 9px;
    color: rgba(255, 255, 255, 0.6);
  }
  /* trasera */
  .center {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 9px;
  }
  .cb-name {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    text-align: center;
  }
  .cb-name span {
    color: #9fe1cb;
  }
  .cb-divider {
    width: 40px;
    height: 1.5px;
    background: rgba(255, 255, 255, 0.28);
  }
  .cb-tagline {
    font-size: 9.5px;
    color: rgba(255, 255, 255, 0.58);
    font-style: italic;
    text-align: center;
    line-height: 1.55;
  }
  .cb-github {
    font-size: 10px;
    color: #9fe1cb;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  /* info -->*/
  .info-strip {
    background: #e1f5ee;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 11px;
    color: #085041;
    width: 356px;
    text-align: center;
    line-height: 1.8;
  }
  .info-strip strong {
    color: #0f6e56;
  }
</style>

